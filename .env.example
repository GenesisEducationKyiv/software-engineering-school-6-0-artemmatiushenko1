# Database Configuration
DATABASE_URL=postgres://user:password@db:5432/github_release_notifier

# Redis Configuration
REDIS_URL=redis://redis:6379
# Cache TTL in seconds (Default: 600 seconds = 10 minutes)
GITHUB_CACHE_TTL=600

# App Configuration
LOG_LEVEL=info
# Set to true in local development for human-readable logs (JSON required for Docker/Filebeat)
LOG_PRETTY=false
PORT=3000
HOST=0.0.0.0
APP_URL=http://localhost:3000
API_PREFIX=/api

# GitHub Configuration
# Optional: Use a token to increase API rate limits
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_API_URL=https://api.github.com

# Email Configuration
# Supported types: smtp, gmail
EMAIL_TYPE=smtp

# SMTP Configuration (if EMAIL_TYPE=smtp)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=optional_user
SMTP_PASS=optional_password
SMTP_SECURE=false
SMTP_FROM=noreply@example.com

# Gmail Configuration (if EMAIL_TYPE=gmail)
GMAIL_USER_EMAIL=your_email@gmail.com
GMAIL_CLIENT_ID=your_google_client_id
GMAIL_CLIENT_SECRET=your_google_client_secret
GMAIL_REFRESH_TOKEN=your_google_refresh_token

# Scanner Configuration
# Cron expression for how often to check for new releases
# Default: every 10 minutes
SCANNER_CRON=*/10 * * * *

# Elasticsearch / Kibana (docker compose --profile logging)
# Password for the built-in elastic superuser (Kibana UI login, curl, Filebeat)
ELASTIC_PASSWORD=changeme
# Password for the kibana_system user (Kibana → Elasticsearch connection only)
KIBANA_SYSTEM_PASSWORD=changeme
# Required by Kibana when security is enabled (min 32 characters)
KIBANA_ENCRYPTION_KEY=min-32-char-local-dev-encryption-key!!
