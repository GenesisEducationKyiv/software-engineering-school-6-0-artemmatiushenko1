{
  "name": "github-release-notifier",
  "version": "1.0.0",
  "description": "An API that allows to subscribe to email notifications about new releases of given github repository.",
  "main": "index.ts",
  "type": "module",
  "scripts": {
    "start": "tsx ./src/index.ts",
    "dev": "NODE_ENV=development tsx watch ./src/index.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "precommit": "lint-staged && npm run lint && npm test",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "db:generate": "npm run db:generate:platform && npm run db:generate:subscription && npm run db:generate:scanner && npm run db:generate:notification",
    "db:generate:platform": "drizzle-kit generate --config=drizzle.platform.config.ts",
    "db:generate:subscription": "drizzle-kit generate --config=drizzle.subscription.config.ts",
    "db:generate:scanner": "drizzle-kit generate --config=drizzle.scanner.config.ts",
    "db:generate:notification": "drizzle-kit generate --config=drizzle.notification.config.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "proto:generate": "protoc --plugin=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=./src/modules/subscription/infrastructure/grpc/generated --ts_proto_opt=outputServices=grpc-js,esModuleInterop=true,importSuffix=.js,useOptionals=messages --proto_path=./src/modules/subscription/api ./src/modules/subscription/api/subscription.proto",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "Artem Matiushenko",
  "lint-staged": {
    "*": "prettier --write --ignore-unknown"
  },
  "dependencies": {
    "@fastify/static": "^9.1.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.8.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.4",
    "ioredis": "^5.10.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "octokit": "^5.0.5",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.5",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@types/ioredis": "^4.28.10",
    "@types/node": "^25.5.2",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/yaml": "^1.9.6",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/eslint-plugin": "^1.6.17",
    "dotenv": "^17.4.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "ts-proto": "^2.12.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.4",
    "vitest-mock-extended": "^4.0.0"
  }
}
